generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BillingType {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
}

enum Category {
  MOBILE
  ACCESSORY
}

enum MovementType {
  PURCHASE_IN
  SALE_OUT
  RETURN
  ADJUSTMENT
}

enum RepairStatus {
  RECEIVED
  IN_REPAIR
  REPAIRED
  DELIVERED
  CANCELLED
}

enum ServiceType {
  MOBILE_RECHARGE
  DTH
  ELECTRICITY
  MONEY_TRANSFER
  OTHER
}

enum PaymentMode {
  CASH
  UPI
  CARD
  CREDIT
}

enum TransactionStatus {
  SUCCESS
  PENDING
  FAILED
}

enum SaleStatus {
  ACTIVE
  CANCELLED
}

enum ActorType {
  ADMIN
  SUB_ADMIN
}

enum AIQuotaCategory {
  OCR_EXTRACT
  FESTIVAL_OFFERS
  SLOW_STOCK
  MONTHLY_STRATEGY
}

model SuperAdmin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("SuperAdmin")
}

model Plan {
  id             String   @id @default(uuid())
  name           String   @unique
  priceMonthly   Decimal  @db.Decimal(10,2)
  priceYearly    Decimal  @db.Decimal(10,2)
  maxProducts    Int?
  maxSubAdmins   Int      @default(0)
  maxShops       Int?
  aiEnabled      Boolean  @default(false)
  features       Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  subscriptions  Subscription[]

  @@map("Plan")
}

model Admin {
  id                 String             @id @default(uuid())
  shopName           String
  ownerName          String
  email              String             @unique
  phone              String             @unique
  passwordHash       String
  address            String?
  city               String?
  state              String?
  gstNumber          String?
  aadhaarDocUrl      String?
  panDocUrl          String?
  shopActDocUrl      String?
  verificationStatus VerificationStatus @default(PENDING)
  verificationNote   String?
  verifiedAt         DateTime?
  isActive           Boolean            @default(true)
  aiLanguagePreference String           @default("HINGLISH")
  /// UI / API locale: en | hi | mr | hi-Latn (S4)
  languagePref       String             @default("en")
  createdAt          DateTime           @default(now())

  subscriptions      Subscription[]
  shops              Shop[]
  subAdmins          SubAdmin[]
  products           Product[]
  sales              Sale[]
  repairs            Repair[]
  recharges          RechargeTransfer[]
  auditLogs          AuditLog[]
  adminModules       AdminModule[]
  invoices           Invoice[]
  customers          Customer[]
  brandDicts         BrandDict[]
  modelDicts         ModelDict[]
  categoryDicts      CategoryDict[]
  issueDicts         IssueDict[]
  operatorDicts      OperatorDict[]
  aIConsumptions     AIConsumption[]
  aITopUps           AITopUp[]
  aIExtractions      AIExtraction[]
  entitlements      Entitlement[]

  @@map("Admin")
}

model Shop {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  city      String?
  isMain    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  subAdmins   SubAdmin[]
  products    Product[]
  sales       Sale[]
  repairs     Repair[]
  recharges   RechargeTransfer[]

  @@map("Shop")
}

model Subscription {
  id               String        @id @default(uuid())
  adminId          String
  admin            Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan          @relation(fields: [planId], references: [id])
  billingType      BillingType
  amountPaid       Decimal       @db.Decimal(10,2)
  startDate        DateTime
  endDate          DateTime
  paymentStatus    PaymentStatus @default(PENDING)
  paymentReference String?
  isCurrent        Boolean       @default(true)
  createdAt        DateTime      @default(now())

  @@map("Subscription")
}

model SubAdmin {
  id           String   @id @default(uuid())
  adminId      String
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id])
  name         String
  email        String
  phone        String
  passwordHash String
  permissions  Json
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())

  @@unique([adminId, email])
  @@map("SubAdmin")
}

model Product {
  id               String      @id @default(uuid())
  adminId          String
  admin            Admin       @relation(fields: [adminId], references: [id], onDelete: Cascade)
  shopId           String
  shop             Shop        @relation(fields: [shopId], references: [id])
  brandName        String
  name             String
  category         Category
  accessoryType    String?
  purchasePrice    Decimal     @db.Decimal(10,2)
  sellingPrice     Decimal     @db.Decimal(10,2)
  stockQty         Int         @default(0)
  lowStockAlertQty Int         @default(5)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())

  saleItems        SaleItem[]
  stockMovements   StockMovement[]
  repairParts      RepairPartUsed[]

  @@map("Product")
}

model StockMovement {
  id           String       @id @default(uuid())
  adminId      String
  productId    String
  product      Product      @relation(fields: [productId], references: [id])
  movementType MovementType
  qty          Int
  referenceId  String?
  notes        String?
  movedAt      DateTime     @default(now())

  @@index([adminId, movedAt])
  @@index([adminId, movementType])
  @@map("StockMovement")
}

model Sale {
  id             String        @id @default(uuid())
  adminId        String
  admin          Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id])
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  saleNumber     String
  createdByType  ActorType
  createdById    String
  saleDate       DateTime      @default(now())
  customerName   String?
  customerPhone  String?
  totalAmount    Decimal       @db.Decimal(10,2)
  discountAmount Decimal       @db.Decimal(10,2) @default(0)
  paymentMode   PaymentMode   @default(CASH)
  status         SaleStatus    @default(ACTIVE)
  amountReceived Decimal       @db.Decimal(10,2) @default(0)
  pendingAmount  Decimal       @db.Decimal(10,2) @default(0)
  notes          String?
  createdAt      DateTime      @default(now())

  items          SaleItem[]

  @@unique([adminId, saleNumber])
  @@index([adminId, saleDate])
  @@index([adminId, createdAt])
  @@index([adminId, customerId])
  @@map("Sale")
}

model SaleItem {
  id                  String  @id @default(uuid())
  saleId              String
  sale                Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId           String
  product             Product @relation(fields: [productId], references: [id])
  qty                 Int
  unitPrice           Decimal @db.Decimal(10,2)
  purchasePriceAtSale Decimal @db.Decimal(10,2)
  subtotal            Decimal @db.Decimal(10,2)

  @@map("SaleItem")
}

model Repair {
  id                String       @id @default(uuid())
  adminId           String
  admin             Admin        @relation(fields: [adminId], references: [id], onDelete: Cascade)
  shopId            String
  shop              Shop         @relation(fields: [shopId], references: [id])
  customerId        String?
  customer          Customer?    @relation(fields: [customerId], references: [id])
  repairNumber      String
  createdByType     ActorType
  createdById       String
  customerName      String
  customerPhone     String
  deviceBrand       String
  deviceModel       String
  issueDescription  String
  repairCost        Decimal      @db.Decimal(10,2) @default(0)
  customerCharge    Decimal      @db.Decimal(10,2) @default(0)
  advancePaid       Decimal      @db.Decimal(10,2) @default(0)
  pendingAmount     Decimal      @db.Decimal(10,2) @default(0)
  status            RepairStatus @default(RECEIVED)
  receivedDate      DateTime     @default(now())
  estimatedDelivery DateTime?
  completionDate    DateTime?
  deliveryDate      DateTime?
  notes             String?
  createdAt         DateTime     @default(now())

  partsUsed         RepairPartUsed[]

  @@unique([adminId, repairNumber])
  @@index([adminId, receivedDate])
  @@index([adminId, status])
  @@index([adminId, createdAt])
  @@index([adminId, customerId])
  @@map("Repair")
}

model RepairPartUsed {
  id        String   @id @default(uuid())
  repairId  String
  repair    Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  partName  String
  qty       Int
  cost      Decimal  @db.Decimal(10,2)

  @@map("RepairPartUsed")
}

model RechargeTransfer {
  id               String            @id @default(uuid())
  adminId          String
  admin            Admin             @relation(fields: [adminId], references: [id], onDelete: Cascade)
  shopId           String
  shop             Shop              @relation(fields: [shopId], references: [id])
  customerId       String?
  customer         Customer?         @relation(fields: [customerId], references: [id])
  createdByType    ActorType
  createdById      String
  serviceType      ServiceType
  customerName     String
  customerPhone    String
  beneficiaryNumber String
  operator         String
  amount           Decimal           @db.Decimal(10,2)
  commissionEarned Decimal           @db.Decimal(8,2) @default(0)
  netProfit        Decimal           @db.Decimal(8,2) @default(0)
  transactionRef    String?
  status           TransactionStatus @default(PENDING)
  transactionDate  DateTime          @default(now())
  notes            String?
  createdAt        DateTime          @default(now())

  @@index([adminId, transactionDate])
  @@index([adminId, serviceType])
  @@index([adminId, customerId])
  @@map("RechargeTransfer")
}

model AuditLog {
  id           String    @id @default(uuid())
  adminId      String
  admin        Admin     @relation(fields: [adminId], references: [id])
  tableName    String
  recordId     String
  fieldName    String
  oldValue     String?
  newValue     String?
  reason       String
  editedByType ActorType
  editedById   String
  editedByName String
  createdAt    DateTime  @default(now())

  @@index([adminId, createdAt])
  @@index([adminId, tableName])
  @@map("AuditLog")
}

model Customer {
  id          String    @id @default(uuid())
  adminId     String
  admin       Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  phoneE164   String
  name        String?
  notes       String?
  languagePref String?
  /// S5: lower(name) + tx_to_latn(name) for pg_trgm cross-script match (DB-generated).
  search      String    @default(dbgenerated("(lower(trim(coalesce(\"name\",''))) || ' ' || lower(trim(coalesce(public.tx_to_latn(coalesce(\"name\",'')),''))))")) @db.Text
  createdAt   DateTime  @default(now())

  sales       Sale[]
  repairs     Repair[]
  recharges   RechargeTransfer[]

  @@unique([adminId, phoneE164])
  @@index([adminId, phoneE164])
  @@map("Customer")
}

model BrandDict {
  id         String    @id @default(uuid())
  adminId    String
  admin      Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  value      String
  valueLatn  String
  useCount   Int       @default(0)
  lastUsedAt DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([adminId])
  @@index([adminId, useCount])
  @@map("BrandDict")
}

model ModelDict {
  id         String    @id @default(uuid())
  adminId    String
  admin      Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  value      String
  valueLatn  String
  useCount   Int       @default(0)
  lastUsedAt DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([adminId])
  @@index([adminId, useCount])
  @@map("ModelDict")
}

model CategoryDict {
  id         String    @id @default(uuid())
  adminId    String
  admin      Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  value      String
  valueLatn  String
  useCount   Int       @default(0)
  lastUsedAt DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([adminId])
  @@index([adminId, useCount])
  @@map("CategoryDict")
}

model IssueDict {
  id         String    @id @default(uuid())
  adminId    String
  admin      Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  value      String
  valueLatn  String
  useCount   Int       @default(0)
  lastUsedAt DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([adminId])
  @@index([adminId, useCount])
  @@map("IssueDict")
}

model OperatorDict {
  id         String    @id @default(uuid())
  adminId    String
  admin      Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  value      String
  valueLatn  String
  useCount   Int       @default(0)
  lastUsedAt DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([adminId])
  @@index([adminId, useCount])
  @@map("OperatorDict")
}

enum ModuleBillingType {
  FREE
  ADDON
}

model Module {
  id           String           @id @default(uuid())
  key          String           @unique
  name         String
  description  String
  category     String
  billingType  ModuleBillingType @default(FREE)
  priceMonthly Decimal?         @db.Decimal(10,2)
  priceYearly  Decimal?         @db.Decimal(10,2)
  isActive     Boolean          @default(true)
  sortOrder    Int              @default(0)
  createdAt    DateTime         @default(now())

  purchases    AdminModule[]

  @@map("Module")
}

model AdminModule {
  id           String          @id @default(uuid())
  adminId      String
  admin        Admin           @relation(fields: [adminId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module          @relation(fields: [moduleId], references: [id])
  status       PaymentStatus   @default(PENDING)
  startDate    DateTime?
  endDate      DateTime?
  autoRenew    Boolean         @default(true)
  purchasedAt  DateTime        @default(now())

  @@unique([adminId, moduleId])
  @@map("AdminModule")
}

model Entitlement {
  id          String    @id @default(uuid())
  adminId     String
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  moduleKey   String
  limitType   String
  maxValue    Int
  usedValue   Int       @default(0)
  resetAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  @@unique([adminId, moduleKey])
  @@map("Entitlement")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

model Invoice {
  id            String        @id @default(uuid())
  adminId       String
  admin         Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  invoiceNumber String        @unique
  amount        Decimal       @db.Decimal(10,2)
  taxAmount     Decimal       @db.Decimal(10,2) @default(0)
  totalAmount   Decimal       @db.Decimal(10,2)
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime?
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())

  payments      Payment[]

  @@index([adminId, createdAt])
  @@map("Invoice")
}

model Payment {
  id              String        @id @default(uuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10,2)
  method          String?
  reference       String?
  status          PaymentStatus @default(PENDING)
  processedAt     DateTime?
  failureReason   String?
  createdAt       DateTime      @default(now())

  @@index([invoiceId])
  @@map("Payment")
}

model AIConsumption {
  id        String         @id @default(uuid())
  adminId   String
  admin     Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  category  AIQuotaCategory
  date      DateTime      @default(now())
  count     Int           @default(1)
  metadata  Json?
  createdAt DateTime      @default(now())

  @@unique([adminId, category, date])
  @@index([adminId, date])
  @@map("AIConsumption")
}

model AITopUp {
  id               String   @id @default(uuid())
  adminId          String
  admin            Admin   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  type             String   // 'OCR' | 'STRATEGY'
  creditsPurchased Int
  creditsUsed      Int      @default(0)
  pricePaid        Decimal  @db.Decimal(10,2)
  purchasedAt      DateTime @default(now())

  @@index([adminId])
  @@map("AITopUp")
}

model AIExtraction {
  id            String    @id @default(uuid())
  adminId       String
  admin         Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  shopId        String?
  imagePath     String
  extractedData Json
  status        String    @default("PENDING") // 'PENDING' | 'CONFIRMED' | 'EXPIRED'
  expiresAt     DateTime
  confirmedAt   DateTime?
  createdAt     DateTime  @default(now())
  /// S6: optional encrypted payload (future KMS); OCR JSON remains in extractedData for now.
  payloadEnc    Bytes?
  imageSha256   String?
  objectKey     String?
  ocrKind       String?
  ocrProvider   String?
  ocrError      String?

  @@index([adminId, status])
  @@index([expiresAt])
  @@map("AIExtraction")
}
