# ============================================
# MobiManager Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ============================================

# ============================================
# REQUIRED - App will fail to start if missing
# ============================================

# Database connection string (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/mobimgr"

# JWT Secret for admin/subadmin tokens (minimum 32 characters)
JWT_SECRET="your-jwt-secret-minimum-32-characters-long"

# JWT Secret for superadmin tokens (minimum 32 characters)
SUPER_ADMIN_JWT_SECRET="your-super-admin-jwt-secret-32chars"

# Node environment
NODE_ENV="development"

# ============================================
# SECURITY
# ============================================

# Allowed CORS origins (comma-separated, no spaces)
# Example: http://localhost:3000,https://app.example.com
ALLOWED_ORIGINS="http://localhost:3000"

# Secret slug for superadmin routes (must be hard to guess)
SA_ROUTE_SLUG="super-admin"

# Allowed IPs for superadmin routes (comma-separated, leave empty to allow all)
# Example: 192.168.1.100,10.0.0.0/8
SA_ALLOWED_IPS=""

# ============================================
# UPLOADS
# ============================================

# Maximum upload size in megabytes
UPLOAD_MAX_SIZE_MB="5"

# Cloudinary configuration (optional - only needed for uploads)
CLOUDINARY_URL=""
# CLOUDINARY_API_SECRET=""

# ============================================
# REDIS (Optional - for rate limiting)
# ============================================
# If not provided, falls back to in-memory rate limiting
# For production, use Redis for distributed rate limiting
# Example: redis://localhost:6379
# Or for Upstash: https://your-instance.upstash.io
REDIS_URL=""

# ============================================
# APPLICATION
# ============================================

NEXT_PUBLIC_APP_NAME="MobiManager"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Logging level: error, warn, info, http, debug
LOG_LEVEL="info"
